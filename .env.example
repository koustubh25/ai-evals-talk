# Experts Live evals demo — environment template.
# Copy to .env (gitignored). No secrets here; keys come from `az` at runtime:
#   az cognitiveservices account keys list -g rg-evals-demo -n evalsdemo-ktb-au --query key1 -o tsv

AZURE_SUBSCRIPTION_ID=5d98f681-c627-4a4d-9f1d-001ae04c2358
AZURE_RESOURCE_GROUP=rg-evals-demo
AZURE_LOCATION=australiaeast

# Foundry
FOUNDRY_ACCOUNT=evalsdemo-ktb-au
FOUNDRY_PROJECT=proj-evals-demo
FOUNDRY_PROJECT_ENDPOINT=https://evalsdemo-ktb-au.services.ai.azure.com/api/projects/proj-evals-demo
MODEL_DEPLOYMENT=gpt-5-mini

# Tracing (fetch full connection string at runtime; do not commit it)
APPINSIGHTS_RESOURCE=appi-evals-demo
# APPLICATIONINSIGHTS_CONNECTION_STRING=<az resource show ... --query properties.ConnectionString>

# Mock inventory service (Phase 3)
INVENTORY_BASE_URL=https://inventory-mock-ktb-au.azurewebsites.net
